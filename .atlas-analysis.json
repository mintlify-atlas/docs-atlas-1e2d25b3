  "keyFeatures": [
    "Multi-copy storage with automatic provider selection",
    "Integrated payment rails with ERC20 and FIL support",
    "Session key delegation for seamless UX",
    "FilBeam CDN integration for fast content delivery",
    "PieceCID utilities and content addressing",
    "Service provider discovery and registry",
    "Browser and Node.js compatibility",
    "TypeScript-first with full type safety"
